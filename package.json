{
  "name": "@missingcore/music-glyph-toys",
  "version": "0.3.0",
  "description": "Glyph Matrix functionality for MissingCore Music app.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "pnpm --filter example run",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MissingCore/music-glyph-toys.git"
  },
  "author": "cyanChill",
  "license": "AGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/MissingCore/music-glyph-toys/issues"
  },
  "homepage": "https://github.com/MissingCore/music-glyph-toys#readme",
  "devDependencies": {
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@react-native/babel-preset": "catalog:",
    "@react-native/eslint-config": "catalog:",
    "@release-it/keep-a-changelog": "7.0.1",
    "@types/jest": "30.0.0",
    "@types/react": "19.2.14",
    "del-cli": "7.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.3.0",
    "prettier": "3.8.3",
    "react": "catalog:",
    "react-native": "catalog:",
    "react-native-builder-bob": "catalog:",
    "release-it": "20.0.1",
    "release-it-pnpm": "4.6.6",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "verbose": true
  },
  "release-it": {
    "git": {
      "tagName": "v${version}",
      "commitMessage": "build: release ${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/keep-a-changelog": {
        "filename": "CHANGELOG.md",
        "addUnreleased": true,
        "addVersionUrl": true
      },
      "release-it-pnpm": {}
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "endOfLine": "auto"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "MusicGlyphToysSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.cyanchill.missingcore.music.toys"
    }
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "jest",
      "release-it",
      "eslint"
    ],
    "version": "0.57.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@weights-ai/react-native-track-player"
    ],
    "patchedDependencies": {
      "@expo/cli": "patches/@expo__cli.patch"
    }
  }
}
